// FUNÇÃO VERIFICAR (Para escrever na DIV e no Console)
function verificar(nomeDoTeste, condicao) {
 var p = document.createElement("p");

 if (condicao) {
    p.innerHTML = "✅ " + nomeDoTeste;
    p.style.color = "green";
    console.log("✅ PASSOU: " + nomeDoTeste);
 } else {
    p.innerHTML = "❌ " + nomeDoTeste;
    p.style.color = "red";
    console.error("❌ FALHOU: " + nomeDoTeste);
 }

 document.getElementById("relatorio-testes").appendChild(p);
}
/* Instruções: Desenvolva a lógica de verificação dentro da função
abaixo.
